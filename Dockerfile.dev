# ==============================================================================
# Stage 1: Builder - Install dependencies in a temporary build environment
# ==============================================================================
FROM python:3.13-alpine3.21 AS builder
# Set Python environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1
# Copy only requirements file first (better layer caching)
COPY requirements.txt /tmp/requirements.txt
# Install build dependencies, create venv, and install Python packages
RUN apk add --no-cache \
    gcc \
    g++ \
    musl-dev \
    linux-headers \
    libffi-dev \
    openssl-dev \
    postgresql-dev \
    jpeg-dev \
    zlib-dev \
    freetype-dev \
    lcms2-dev \
    openjpeg-dev \
    tiff-dev \
    tk-dev \
    tcl-dev && \
# Create virtual environment for dependency isolation
    python -m venv /opt/venv && \
# Install Python dependencies in the virtual environment
    /opt/venv/bin/pip install --no-cache-dir -r /tmp/requirements.txt
# Activate virtual environment
ENV PATH="/opt/venv/bin:$PATH"


# ==============================================================================
# Stage 2: Runtime - Create minimal production image
# ==============================================================================
FROM python:3.13-alpine3.21 AS runtime
# Set Python environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/opt/venv/bin:$PATH"
# Install runtime dependencies and create non-root user
RUN apk add --no-cache \
    libpq \
    libjpeg-turbo \
    zlib \
    freetype \
    lcms2 \
    openjpeg \
    tiff \
    tk \
    tcl \
    libffi \
    openssl \
    wget && \
    addgroup -g 1000 appuser && \
    adduser -D -u 1000 -G appuser appuser && \
    mkdir -p /app /opt && \
    chown -R root:root /app /opt
# Set working directory
WORKDIR /app
# Copy virtual environment from builder stage
COPY --from=builder --chown=root:root --chmod=755 /opt/venv /opt/venv
# Copy application source code and remove write permissions
COPY --chown=root:root --chmod=755 src /app
# Switch to non-root user
USER appuser
# Expose application port
EXPOSE 8000
# Run application with uvicorn
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]